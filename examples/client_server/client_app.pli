  main: proc options(main);

 %include net;

   dcl conn     like net_t;
   dcl host     char(256);
   dcl port     fixed bin(31) init(8090);
   dcl request  char(256) varying;
   dcl response char(4096);
   dcl bytes    size_t;

   on attention begin;
     call net_close(conn);
     put skip list('Client shut down');
     stop;
   end;

   host = '127.0.0.1';
   request = 'Hello from PL/I client!' || LINE_END;

   put skip list('Connecting to', trim(host), port);

   call net_new(conn, AF.INET, TYPE.STREAM, 0);
   call net_dial(conn, host, port);
   put skip list('Connected');

   bytes = net_write(conn, request);
   put skip list('Sent', bytes, 'bytes');

   bytes = net_read(conn, response);
   if bytes > 0 then
     put skip list('Received:', substr(response, 1, bytes));
   else
     put skip list('No response received');

   call net_close(conn);
   put skip list('Client done');
 end main;
